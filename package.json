{
  "name": "poweremail-direct-dispatcher",
  "version": "0.1.0",
  "description": "Direct broadcast dispatcher for PowerEmail without Sendy as scheduler",
  "main": "src/campaign-intake.js",
  "type": "commonjs",
  "scripts": {
    "intake": "node src/campaign-intake.js",
    "resolve": "node src/audience-resolver.js",
    "plan-batches": "node src/batch-planner.js",
    "execute": "node src/relay-executor.js",
    "prepare-dispatch": "node src/prepare-dispatch-run.js",
    "orchestrate:test": "node -r ./src/test-mail-copy-ai-guard.js src/test-mail-orchestrator.js",
    "orchestrate:test:config-plan": "node scripts/preview-test-orchestrator-config.js",
    "orchestrate:test:cron": "bash scripts/run-test-orchestrator-cron.sh",
    "check:intake": "node --check src/campaign-intake.js",
    "check:prepare": "node --check src/prepare-dispatch-run.js",
    "check:resolve": "node --check src/audience-resolver.js",
    "check:plan": "node --check src/batch-planner.js",
    "check:execute": "node --check src/relay-executor.js",
    "check:orchestrate-test": "node --check src/test-mail-orchestrator.js && node --check src/test-mail-copy-ai-guard.js",
    "check:orchestrate-test-config-plan": "node --check scripts/preview-test-orchestrator-config.js",
    "check:fingerprint-variant": "node --check src/fingerprint/variant-generator.js && node --check src/fingerprint/similarity-validator.js",
    "check:orchestrate-test:cron": "bash -n scripts/run-test-orchestrator-cron.sh",
    "start": "node -r ./src/worker-loop.js src/server.js"
  },
  "dependencies": {
    "mysql2": "^3.11.3",
    "nodemailer": "^8.0.7",
    "pg": "^8.12.0"
  }
}
